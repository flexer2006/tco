VAULT_ROOT=./vault
MANIFEST_PATH=./vault/_meta/manifest.json
HTTP_BIND=127.0.0.1
HTTP_PORT=8080
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_CHAT_ID=
RUNTIME_PROFILE=real
TELEGRAM_SOURCE_MODE=live
TELEGRAM_SESSION_PATH=./vault/_meta/telegram.session.json
TELEGRAM_PROXY_ADDR=
TELEGRAM_AUTH_TIMEOUT=9s
TELEGRAM_FIXTURE_PATH=./vault/raw/messages.json
TELEGRAM_INCLUDE_ALL_MESSAGES=true
RUN_MODE=full_rebuild
BATCH_MODE=streaming
BATCH_SIZE=32
EMBED_MODEL_ID=all-MiniLM-L6-v2-go
EMBED_MODEL_PATH=./models/all-MiniLM-L6-v2.onnx
EMBED_VECTOR_DIMENSION=384
ONNXRUNTIME_SHARED_LIBRARY=./models/libonnxruntime.so
ONNX_INPUT_NAME=
ONNX_OUTPUT_NAME=
DEDUP_SIMILARITY_THRESHOLD=0.95
CLUSTER_SIMILARITY_THRESHOLD=0.80
LOG_LEVEL=info
EMBED_MODEL_PROFILE=bert_tokenized_mean_pooling
